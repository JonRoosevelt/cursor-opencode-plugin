CURSOR_BIN_PATH=cursor-agent
ADAPTER_HOST=127.0.0.1
ADAPTER_PORT=8787
DEFAULT_CWD=.
REQUEST_TIMEOUT_MS=120000
LOG_LEVEL=info
CURSOR_MODEL_ID=cursor-agent/default
CURSOR_MODEL_ALIASES=cursor-agent/default,claude-4-6-sonnet
CURSOR_ACCEPT_ANY_MODEL=true
CURSOR_MODEL_ARG=--model
CURSOR_DISCOVER_MODELS=true
# JSON array or space-delimited args used to discover available cursor-agent models.
CURSOR_MODELS_ARGS=models
CURSOR_MODELS_CACHE_TTL_MS=300000
CURSOR_PROMPT_MODE=stdin
CURSOR_PROMPT_ARG=--prompt
# JSON array or space-delimited args.
CURSOR_BASE_ARGS=[]
MAX_STDOUT_BYTES=500000
ENABLE_GREETING_FAST_PATH=true
GREETING_FAST_PATH_RESPONSE=Hi! What can I help you build or debug today?
PROMPT_MAX_CONVERSATION_MESSAGES=10
PROMPT_MAX_MESSAGE_CHARS=2000
PROMPT_MAX_CHARS=12000
RESPONSE_CACHE_TTL_MS=60000
RESPONSE_CACHE_MAX_ENTRIES=200
ENABLE_CURSOR_SESSIONS=true
CURSOR_SESSION_FALLBACK_TO_CWD=true
CURSOR_SESSION_TTL_MS=1800000
CURSOR_SESSION_MAX_ENTRIES=500
